      isMinimized = !isMinimized;
      main.classList.toggle('collapsed', isMinimized);
      footer.style.display = isMinimized ? 'none' : '';
      minBtn.innerHTML = isMinimized ? ICON_EXPAND : ICON_MINIMIZE;
    });

    makeDraggable(panel, header);
  }

  // ─── DRAG ─────────────────────────────────────────────────────
  // COMPLETELY REWRITTEN: uses getBoundingClientRect for viewport-relative positioning
  // and correct delta math. No more offsetTop/offsetLeft bugs.
  function makeDraggable(el, handle) {
    let isDragging = false;
    let startX = 0, startY = 0;
    let startLeft = 0, startTop = 0;

    handle.addEventListener('mousedown', e => {
      if (e.target.closest('#rwa-minimize-btn')) return;
      e.preventDefault();

      const rect = el.getBoundingClientRect();
      startX = e.clientX;
      startY = e.clientY;
      startLeft = rect.left;
      startTop = rect.top;

      isDragging = true;
      document.body.style.cursor = 'grabbing';
      handle.style.cursor = 'grabbing';
      el.style.transition = 'none'; // Disable transitions during drag for responsiveness

      const onMove = e2 => {
        if (!isDragging) return;
        const dx = e2.clientX - startX;
        const dy = e2.clientY - startY;
        el.style.left = (startLeft + dx) + 'px';
        el.style.top = (startTop + dy) + 'px';
        el.style.right = 'auto';
        el.style.bottom = 'auto';
      };

      const onUp = () => {
        isDragging = false;
        document.removeEventListener('mousemove', onMove);
        document.removeEventListener('mouseup', onUp);
        document.body.style.cursor = '';
        handle.style.cursor = 'grab';
        el.style.transition = ''; // Re-enable transitions
      };

      document.addEventListener('mousemove', onMove);
      document.addEventListener('mouseup', onUp);
    });
  }

  // ─── INIT ─────────────────────────────────────────────────────
  function init() {
    if (typeof Notification !== 'undefined' && Notification.permission === 'default') {
      Notification.requestPermission();
    }
    createUI();
    startMonitor();
  }

  window.addEventListener('load', () => {
    setTimeout(() => {
      init();
    }, 5000);
  });

})();
