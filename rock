  // ─── RAT ALERT ────────────────────────────────────────────────────
  function playAlert() {
    if (!SETTINGS.playSoundAlert) return;
    try {
      const ctx = new (window.AudioContext || window.webkitAudioContext)();
      const beep = (f, s, d) => {
        const o = ctx.createOscillator(), g = ctx.createGain();
        o.connect(g); g.connect(ctx.destination);
        o.type = 'sine';
        o.frequency.setValueAtTime(f, ctx.currentTime + s);
        g.gain.setValueAtTime(0.22, ctx.currentTime + s);
        g.gain.exponentialRampToValueAtTime(0.001, ctx.currentTime + s + d);
        o.start(ctx.currentTime + s);
        o.stop(ctx.currentTime + s + d);
      };
      beep(880, 0, 0.12); beep(1100, 0.15, 0.12); beep(1320, 0.30, 0.22);
    } catch (e) { console.warn('[RWA] sound error', e); }
  }

  // ─── NOTIFICATION ────────────────────────────────────────────
  function sendNotification(title, body) {
    if (!SETTINGS.browserNotif) return;
    try {
      GM_notification({ title, text: body, image: 'https://bigrat.monster/media/bigrat.jpg', timeout: 8000, onclick: () => window.focus() });
    } catch {
      if (Notification.permission === 'granted') {
        const n = new Notification(title, { body });
        n.onclick = () => window.focus();
      } else if (Notification.permission !== 'denied') {
        Notification.requestPermission().then(p => { if (p === 'granted') sendNotification(title, body); });
      }
    }
  }

  // || MATCHING ( PART OF DTC ) ||
  function matchLicence(productName, duration) {
    const pLower = productName.toLowerCase().trim();
    const dLower = duration.toLowerCase().trim();
    for (const [pk, pdata] of Object.entries(PRODUCTS)) {
      if (pLower !== pdata.label.toLowerCase()) continue;
      for (const [vk, variant] of Object.entries(pdata.variants)) {
        if (!variant.enabled) continue;
        if (!variant.durationKw || dLower.includes(variant.durationKw)) {
          return { productKey: pk, variantKey: vk, product: pdata, variant };
        }
      }
      if (SETTINGS.alertForUnknown) {
        return { productKey: pk, variantKey: 'unknown', product: pdata, variant: null };
      }
      return null;
    }
    if (SETTINGS.alertForUnknown) return { productKey: 'unknown', variantKey: '', product: null, variant: null };
    return null;
  }

  // || MAIN DTC ||
  const CARD_SEL = 'button.weao-_730a2e';
  const NAME_SEL = 'p.weao-_acd684';
  const DUR_SEL = 'span.weao-_30b24a';

  function findAvailableLicences() {
    const results = [];
    const recentEl = document.querySelector('div.weao-_ea4c6c');

    document.querySelectorAll(CARD_SEL).forEach(card => {
      if (recentEl && recentEl.contains(card)) return;
      const stockText = card.innerText.toLowerCase();
      if (stockText.includes('out of stock')) return;
      const nameEl = card.querySelector(NAME_SEL);
      const durEl = card.querySelector(DUR_SEL);
      if (!nameEl) return;
      const productName = nameEl.textContent.trim();
      const duration = durEl ? durEl.textContent.trim() : '';
      const match = matchLicence(productName, duration);
      if (!match) return;
      const title = duration ? productName + ' \u00b7 ' + duration : productName;
      const uid = productName + '|' + duration;
      results.push({ title, uid, element: card, ...match });
    });
    return results;
  }

  // || HANDLERS ||
  function handleNewLicence(lic) {
    const id = lic.uid || (lic.productKey + '|' + lic.variantKey);
    if (seenLicences.has(id)) return;
    seenLicences.add(id);
    GM_setValue('seenLicences', [...seenLicences]);
    const pLabel = lic.product ? lic.product.label : 'Unknown';
    const vLabel = lic.variant ? lic.variant.label : '';
    const color = lic.product ? lic.product.color : 'rgba(255,255,255,0.4)';
    const fullLabel = vLabel ? pLabel + ' \u00b7 ' + vLabel : pLabel;
    console.log('[RWA] LICENCE IN STOCK:', fullLabel, '| uid:', id);
    setStatus('found', 'Available: ' + fullLabel);
    addLog(pLabel, vLabel, color);
    playAlert();
    sendNotification(
      '\uD83D\uDD11 ' + fullLabel + ' \u2014 Rock Weao Announcer',
      'Licence available! Trying to claim!'
    );
    try {
      lic.element.scrollIntoView({ behavior: 'smooth', block: 'center' });
      lic.element.style.outline = '3px solid ' + color;
      lic.element.style.borderRadius = '10px';
      lic.element.style.boxShadow = '0 0 18px ' + color + '55';
    } catch (_) {}
    if (SETTINGS.autoOpenTab) {
      setTimeout(() => { try { lic.element.click(); } catch (_) {} }, 600);
    }
  }

  // || POLLS ||
  function poll() {
    const cards = document.querySelectorAll(CARD_SEL);
    console.log('CARDS FOUND:', cards.length);
    cards.forEach(card => {
      console.log({
        text: card.innerText,
        disabled: card.disabled,
        aria: card.getAttribute('aria-disabled')
      });
    });
    const found = findAvailableLicences();
    console.log('AVAILABLE:', found);
    if (found.length === 0) setStatus('watching', 'Waiting for licence\u2026');
    found.forEach(handleNewLicence);
  }

  function startMonitor() {
    if (monitorActive) return;
    monitorActive = true;
    poll();
    setInterval(() => {
      try {
        poll();
      } catch (e) {
        console.error('[RWA ERROR]', e);
      }
    }, SETTINGS.pollInterval);
  }

